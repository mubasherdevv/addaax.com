RewriteEngine On

# 1. Remove index.php from URL
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.php\ HTTP/
RewriteRule ^index\.php$ / [R=301,L]

# 2. Map escorts to products.php
RewriteRule ^escorts/?$ products.php [NC,L]
RewriteRule ^escorts/([^/]+)/?$ products.php?city=$1 [NC,QSA,L]

# 3. Add .php extension internally
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# 4. Map ad/slug-id to product_details.php
RewriteRule ^ad/[a-z0-9-]+-([0-9]+)/?$ product_details.php?id=$1 [NC,QSA,L]
